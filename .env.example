# =============================================================================
# EdTech Platform Environment Configuration
# =============================================================================
# This is a template file. Copy to .env and update with your actual values.
# DO NOT commit .env files to version control!

# =============================================================================
# Application Environment
# =============================================================================
NODE_ENV=development
DEBUG=true
LOG_LEVEL=info

# =============================================================================
# Server Configuration
# =============================================================================
PORT=5000
HOST=0.0.0.0
API_VERSION=v1

# =============================================================================
# Frontend Configuration
# =============================================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# IMPORTANT: Generate a strong password and never commit it to version control!
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=edtech_platform
DATABASE_USER=edtech_user
DATABASE_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DATABASE_MAX_CONNECTIONS=20
DATABASE_SSL=false

# Full database URL (alternative to individual settings)
DATABASE_URL=postgresql://edtech_user:YOUR_SECURE_PASSWORD_HERE@localhost:5432/edtech_platform

# =============================================================================
# Redis Configuration (Caching)
# =============================================================================
# IMPORTANT: Generate a strong password for Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_DB=0
REDIS_URL=redis://:YOUR_REDIS_PASSWORD_HERE@localhost:6379/0

# =============================================================================
# JWT & Authentication
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please-make-it-longer
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-please-make-it-longer
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
COOKIE_SECRET=your-cookie-secret-change-in-production

# =============================================================================
# AI Services Configuration
# =============================================================================
AI_SERVICE_URL=http://localhost:8000
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Model Configuration
ENABLE_MODEL_DOWNLOAD=true
MODEL_CACHE_DIR=./data/models

# OpenClaw AI Agent
OPENCLAW_API_KEY=your-openclaw-api-key

# =============================================================================
# Code Evaluation Services
# =============================================================================
JUDGE0_API_KEY=your-judge0-api-key
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# =============================================================================
# Email Services (Optional)
# =============================================================================
SENDGRID_API_KEY=your-sendgrid-api-key
# Alternative: Resend (https://resend.com — free tier: 3,000 emails/month)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@bluelearnerhub.com
# SMTP configuration is defined later under the "Email / Sales" section
# to avoid duplication and allow sales-system overrides.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-email-password

# =============================================================================
# File Storage (AWS S3 - Optional)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=edtech-platform-files

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Monitoring & Analytics (Optional)
# =============================================================================
SENTRY_DSN=your-sentry-dsn-for-error-tracking
GOOGLE_ANALYTICS_ID=your-google-analytics-id

# =============================================================================
# Development Tools
# =============================================================================
# Set to true to enable React Query Devtools
ENABLE_DEVTOOLS=true

# Set to true to enable detailed SQL logging
ENABLE_SQL_LOGGING=false

# Set to true to seed database with sample data
ENABLE_DATABASE_SEEDING=false

# =============================================================================
# Docker Configuration
# =============================================================================
# These are used when running with docker-compose

# PostgreSQL (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edtech_platform

# Redis (Docker) - password only
REDIS_PASSWORD=redis123

# =============================================================================
# Security Configuration
# =============================================================================
# Enable/disable security features
ENABLE_HELMET=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true

# Trusted proxy settings (for production)
TRUST_PROXY=false

# =============================================================================
# Performance Configuration
# =============================================================================
# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Enable compression
ENABLE_COMPRESSION=true

# Enable caching
ENABLE_CACHING=true
CACHE_TTL=3600

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_QUIZ_FEATURE=true
ENABLE_HACKATHON_FEATURE=true
ENABLE_JOB_FEATURE=true
ENABLE_LEARNING_FEATURE=true
ENABLE_AI_FEATURES=true

# =============================================================================
# AI Model Configuration
# =============================================================================
AIRLLM_MODEL_PATH=./ai_model/knowledge_base/model.bin   # path to local model file

# =============================================================================
# Supabase Configuration (optional)
# =============================================================================
SUPABASE_URL=
SUPABASE_KEY=

# =============================================================================
# Telegram Bot
# =============================================================================
TELEGRAM_TOKEN=your-telegram-bot-token

# =============================================================================
# Email / Sales
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
CRM_STORAGE_PATH=sales_system/crm.json

# =============================================================================
# Backup Configuration (Optional)
# =============================================================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Notes:
# =============================================================================
# 1. Copy this file to .env in the same directory
# 2. Update all placeholder values with your actual configuration
# 3. Never commit .env files to version control
# 4. Use strong, unique passwords in production
# 5. Consider using environment-specific files (.env.development, .env.production)
# 6. Some services are optional - remove unused configurations
# 7. Refer to documentation for service-specific setup instructions
{
  "name": "edtech-platform",
  "version": "1.0.0",
  "description": "BluelearnerHub - Comprehensive EdTech Platform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "backend/AI_core/ai-services"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:install": "npx playwright install --with-deps chromium",
    "dev:ai": "cd ai-services && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:agent": "cd ai-agent && python agent.py",
    "dev:ai-system": "cd ai_system && python orchestrator.py",
    "dev:telegram": "cd telegram_bot && python bot.py",
    "dev:sales": "cd sales_system && python -c \"from lead_generator import generate_segments; print(generate_segments('test')); from email_writer import draft_email; print(draft_email('Test subject','recipient@example.com'))\"",
    "build": "npm run build:all",
    "build:all": "npm-run-all build:backend build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:ai": "cd ai-services && pip install -r requirements.txt",
    "start": "cd backend && npm start",
    "start:all": "npm-run-all --parallel start:frontend start:backend start:ai",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "start:ai": "cd ai-services && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "test": "npm-run-all test:*",
    "test:frontend": "cd frontend && npm test -- --watchAll=false",
    "test:backend": "cd backend && npm test",
    "test:ai": "node -e \"const fs=require('fs'); const cp=require('child_process'); if(!fs.existsSync('ai-services')){console.log('ai-services directory missing; skipping AI tests'); process.exit(0);} try{cp.execSync('python -m pytest --version',{stdio:'ignore'});} catch {console.log('pytest missing; skipping AI tests'); process.exit(0);} cp.execSync('python -m pytest',{stdio:'inherit'});\"",
    "lint": "npm-run-all lint:*",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans && docker system prune -f",
    "setup": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "setup:prod": "npm ci && cd frontend && npm ci && cd ../backend && npm ci",
    "clean": "npm-run-all clean:*",
    "clean:frontend": "cd frontend && rm -rf .next node_modules",
    "clean:backend": "cd backend && rm -rf dist node_modules",
    "clean:all": "rm -rf node_modules && npm run clean",
    "db:migrate": "cd backend && npx prisma migrate deploy || cd database && psql $DATABASE_URL -f migrations/001_full_schema.sql",
    "db:seed": "cd backend && npx prisma db seed || cd database && psql $DATABASE_URL -f seeds/sample_data.sql",
    "db:reset": "cd backend && npx prisma migrate reset --force",
    "deploy:vercel": "cd frontend && vercel --prod",
    "deploy:railway": "railway up",
    "deploy:aws": "./aws/deploy.sh",
    "deploy:docker": "docker-compose -f docker-compose.prod.yml up -d",
    "heroku-postbuild": "npm run setup:prod && npm run build:all",
    "railway:build": "npm run setup:prod && npm run build:all",
    "vercel-build": "cd frontend && npm ci && npm run build",
    "aws:build": "npm run setup:prod && npm run build:all && docker-compose build"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bluelearnerhub/edtech-platform.git"
  },
  "keywords": [
    "edtech",
    "education",
    "learning",
    "platform",
    "nextjs",
    "express",
    "fastapi",
    "ai",
    "hackathon",
    "jobs"
  ],
  "author": "BluelearnerHub Team",
  "license": "MIT",
  "dependencies": {
    "@replit/connectors-sdk": "^0.2.0",
    "dotenv": "^17.3.1"
  }
}

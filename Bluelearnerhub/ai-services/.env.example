# ==============================================================================
# EdTech AI Services - Environment Configuration
# ==============================================================================
# Copy this file to .env and update values for your environment

# ==============================================================================
# Application Configuration
# ==============================================================================
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=INFO

# ==============================================================================
# Server Configuration
# ==============================================================================
HOST=0.0.0.0
PORT=8000

# ==============================================================================
# Database Configuration
# ==============================================================================
# IMPORTANT: Generate a strong password and never commit it to version control!
DATABASE_URL=postgresql://edtech_user:YOUR_SECURE_PASSWORD_HERE@localhost:5432/edtech_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=edtech_user
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_DB=edtech_db

# ==============================================================================
# MongoDB Configuration
# ==============================================================================
# IMPORTANT: Generate a strong password for MongoDB
MONGODB_URI=mongodb://localhost:27017/edtech_logs
MONGO_USER=admin
MONGO_PASSWORD=YOUR_MONGO_PASSWORD_HERE
MONGO_DB=edtech_logs
MONGO_HOST=localhost
MONGO_PORT=27017

# ==============================================================================
# Redis Configuration
# ==============================================================================
# IMPORTANT: Generate a strong password for Redis
REDIS_URL=redis://:YOUR_REDIS_PASSWORD_HERE@localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================================================================
# AI API Keys - KEEP SECURE!
# ==============================================================================
# CRITICAL: Get your API key from https://makersuite.google.com/app/apikey
# NEVER commit this key to version control!
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ==============================================================================
# Model Configuration
# ==============================================================================
QUESTION_GEN_MODEL=gpt-3.5-turbo
RESPONSE_EVAL_MODEL=gpt-3.5-turbo
CODE_EVAL_MODEL=judge0
DEVICE=cpu

# ==============================================================================
# ML/Training Settings
# ==============================================================================
MODELS_DIR=data/models
DATA_DIR=data
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=10
MAX_SEQUENCE_LENGTH=512

# ==============================================================================
# Cache Configuration
# ==============================================================================
CACHE_TTL=3600

# ==============================================================================
# JWT Configuration
# ==============================================================================
JWT_SECRET=your-super-secure-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=86400

# ==============================================================================
# Celery Configuration
# ==============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==============================================================================
# CORS Configuration (comma-separated for multiple origins)
# ==============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:4000

# ==============================================================================
# Email Service (SendGrid)
# ==============================================================================
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@edtech-platform.com

# ==============================================================================
# AWS Configuration (for S3 storage)
# ==============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=edtech-platform-files

# ==============================================================================
# Optional: External Service Integration
# ==============================================================================
# SENTRY_DSN=your_sentry_dsn_for_error_tracking
# DATADOG_API_KEY=your_datadog_api_key

JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# Python Environment
ENVIRONMENT=development

# Server Port
AI_SERVICE_PORT=8000

# Model Configuration
QUESTION_GEN_MODEL=gpt-3.5-turbo
RESPONSE_EVAL_MODEL=gpt-3.5-turbo
CODE_EVAL_MODEL=judge0

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/ai_service.log

# Debug Mode
DEBUG=True

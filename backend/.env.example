# Database Configuration
# IMPORTANT: Generate a strong password and never commit it to version control!
POSTGRES_USER=edtech_user
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_DB=edtech_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://edtech_user:YOUR_SECURE_PASSWORD_HERE@localhost:5432/edtech_db

# MongoDB Configuration
# IMPORTANT: Generate a strong password for MongoDB
MONGO_USER=admin
MONGO_PASSWORD=YOUR_MONGO_PASSWORD_HERE
MONGO_DB=edtech_logs
MONGO_HOST=localhost
MONGO_PORT=27017

MONGODB_URI=mongodb://admin:YOUR_MONGO_PASSWORD_HERE@localhost:27017/edtech_logs?authSource=admin

# Redis Configuration
# IMPORTANT: Generate a strong password for Redis
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:YOUR_REDIS_PASSWORD_HERE@localhost:6379

# RabbitMQ Configuration
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=RabbitPassword123!
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# JWT Configuration
JWT_SECRET=YourSuperSecretJWTKey123!ChangeThisInProduction
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=YourRefreshTokenSecret456!ChangeThis
JWT_REFRESH_EXPIRES_IN=30d

# API Keys - AI Services
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# AWS Configuration (for S3)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=edtech-platform-files

# Email Service (SendGrid)
EMAIL_FROM=noreply@edtech-platform.com
SENDGRID_API_KEY=your_sendgrid_api_key_here

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Code Execution Service
JUDGE0_API_KEY=your_judge0_api_key
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# Node Environment
NODE_ENV=development

# Server Ports
BACKEND_PORT=4000
AI_SERVICE_PORT=8000
FRONTEND_PORT=3000

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Session Configuration
SESSION_SECRET=YourSessionSecret789!ChangeThis
COOKIE_SECRET=YourCookieSecret012!ChangeThis

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png,.zip,.dwg,.dxf,.step,.stl

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

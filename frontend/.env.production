# Production environment — used by Vercel during `next build`
# Override these in the Vercel dashboard if the Render service URL differs.
# api.ts already appends /api to this base URL — do NOT include /api here.
NEXT_PUBLIC_API_URL=https://bluelearnerhub-backend.onrender.com
NEXT_PUBLIC_WS_URL=wss://bluelearnerhub-backend.onrender.com
NEXT_PUBLIC_APP_NAME=BlueLearnerHub
NEXT_PUBLIC_APP_VERSION=1.0.0
